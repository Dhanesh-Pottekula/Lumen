{
  "name": "lumen",
  "private": true,
  "version": "1.0.0",
  "description": "Lumen turns language models into animators: a small JSON grammar an LLM writes, compiled into a deterministic, seekable explainer film rendered live on an HTML5 canvas.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0"
  }
}
